[MASTER]
jobs=1

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-function-docstring,
    redefined-outer-name,
    too-many-arguments,
    too-many-positional-arguments,
    too-many-locals,
    too-few-public-methods,
    too-many-instance-attributes,
    too-many-branches,
    too-many-statements,
    too-many-return-statements,
    import-outside-toplevel,
    global-statement,
    duplicate-code,
    fixme,
    broad-exception-caught,
    import-error

[FORMAT]
max-line-length=80
indent-string='    '

[DESIGN]
max-args=10
max-locals=20
max-attributes=15

[BASIC]
good-names=i,j,k,x,y,n,p,g,df,ax,e,f,v,t,r,rng,dx,dy,nx,ny,fx,fy

[SIMILARITIES]
min-similarity-lines=10

[TYPECHECK]
ignored-modules=numpy,pandas,matplotlib,seaborn,scipy,mesa

[REPORTS]
output-format=text
score=yes
